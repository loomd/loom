{
  "productName": "Loom",
  "version": "0.2.11",
  "identifier": "com.loom.app",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Loom",
        "width": 1024,
        "height": 768,
        "dragDropEnabled": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdFOTNCQkE4RUE3MDQ5MDQKUldRRVNYRHFxTHVUZmhBN2p4bU9kMWdkQkYycHNHWmZxb3VQNGRFOU93aDdTOVpHdTJndWNZVmEK",
      "endpoints": [
        "https://github.com/GoldTest/Loom/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}