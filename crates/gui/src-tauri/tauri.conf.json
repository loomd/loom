{
  "productName": "Loom",
  "version": "0.4.7",
  "identifier": "com.loom.app",
  "build": {
    "beforeDevCommand": "npm --prefix ../crates/gui/frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Loom",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 560,
        "dragDropEnabled": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDRENFMjE0NDlFMUU2ODMKUldTRDV1RkpGT0xjekJKa0I3T0hTN2NIdGo1SENqZHhBcDBjOWRXakE0T2ZycU8yeHRuTXZ3TmsK",
      "endpoints": [
        "https://github.com/loomd/loom/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}