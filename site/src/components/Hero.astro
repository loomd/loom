---
---

<section class="hero-section">
  <div class="container">
    <div class="hero-badge">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
      </svg>
      Multi-Project · Multi-Agent · Terminal
    </div>

    <h1 class="hero-title">
      All Your CLI in One<br />
      <span class="highlight">Beautiful Interface</span>
    </h1>

    <p class="hero-subtitle">
      Loom is a desktop application that manages, categorizes, and runs all your project CLI processes.
      Discover agents, isolate environments, and monitor everything from a single terminal.
    </p>

    <div class="hero-actions">
      <a
        href="https://github.com/loomd/loom/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download for Windows
      </a>
      <a
        href="https://github.com/loomd/loom"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-ghost"
      >
        Star on GitHub
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </a>
    </div>

    <div class="hero-screenshot">
      <div class="hero-screenshot-frame">
        <div class="hero-screenshot-dots">
          <span class="hero-screenshot-dot"></span>
          <span class="hero-screenshot-dot"></span>
          <span class="hero-screenshot-dot"></span>
        </div>
        <img
          src="/20260706-124550.jpg"
          alt="Loom Screenshot"
          width="900"
          height="560"
        />
      </div>
    </div>
  </div>
</section>