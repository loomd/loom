---
---

<section id="download" class="download-section">
  <div class="container">
    <div class="download-card">
      <span class="section-label">Download</span>
      <h2 class="section-title">Get Started</h2>
      <p class="section-desc" style="margin: 0 auto;">
        Download the latest release and start managing your projects in minutes.
      </p>

      <div class="download-actions">
        <a
          href="https://github.com/loomd/loom/releases/latest"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Installer (.exe)
        </a>
        <a
          href="https://github.com/loomd/loom/releases/latest"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-ghost"
        >
          Portable (.zip)
        </a>
      </div>

      <p class="download-info">
        <span>Windows x64</span> · <span>MIT License</span> · <span>Open Source</span>
      </p>
    </div>
  </div>
</section>